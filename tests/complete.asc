// Complex test file for Alpha language compiler
// Tests functions, tables, control flow, and library functions

// Global variables
x = 10;
y = 20;
nl = "\n";

// Function to calculate factorial
function factorial(n) {
    if (n <= 1)
        return 1;
    else
        return n * factorial(n - 1);
}

// Function to find maximum of two numbers
function max(a, b) {
    if (a > b)
        return a;
    else
        return b;
}

// Function that works with tables
function sum_array(arr) {
    local total = 0;
    local i = 0;
    
    while (i < 5) {
        total = total + arr[i];
        i = i + 1;
    }
    
    return total;
}

// Create and populate a table
numbers = [1, 2, 3, 4, 5];
print("Array contents: ");
for (local i = 0; i < 5; ++i) {
    print(numbers[i], " ");
}
print(nl);

// Test arithmetic operations
result = x + y * 2;
print("Arithmetic result: ", result, nl);

// Test function calls
fact5 = factorial(5);
print("Factorial of 5: ", fact5, nl);

maximum = max(x, y);
print("Maximum of ", x, " and ", y, ": ", maximum, nl);

// Test table function
array_sum = sum_array(numbers);
print("Sum of array: ", array_sum, nl);

// Test conditional logic
if (x < y) {
    print("x is less than y", nl);
} else {
    print("x is greater than or equal to y", nl);
}

// Create a more complex table with mixed data
person = [
    {"name": "Alice"},
    {"age": 30},
    {"city": "New York"}
];

print("Person name: ", person["name"], nl);
print("Person age: ", person["age"], nl);

// Test nested function calls
nested_result = max(factorial(3), sum_array(numbers));
print("Nested function result: ", nested_result, nl);

// Test library functions
print("Type of numbers table: ", typeof(numbers), nl);
print("Total members in person: ", objecttotalmembers(person), nl);

// Test string operations
greeting = "Hello, Alpha!";
print(greeting, nl);

// Test boolean operations
flag1 = true;
flag2 = false;
combined = flag1 and not flag2;
print("Boolean result: ", combined, nl);

print("Test completed successfully!", nl);